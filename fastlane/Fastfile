default_platform(:ios)

# ─── Android ────────────────────────────────────────────────

platform :android do
  desc "Build release AAB for Play Store"
  lane :build do
    sh("cd ../.. && flutter build appbundle --release")
  end

  desc "Build and upload to Play Store internal test track"
  lane :beta do
    sh("cd ../.. && flutter build appbundle --release")

    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      json_key: play_store_key_path,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Promote internal to production"
  lane :promote do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      json_key: play_store_key_path,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Upload metadata and screenshots to Play Store"
  lane :metadata do
    upload_to_play_store(
      json_key: play_store_key_path,
      skip_upload_aab: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      metadata_path: "fastlane/metadata/android"
    )
  end

  desc "Upload metadata only (no screenshots)"
  lane :metadata_only do
    upload_to_play_store(
      json_key: play_store_key_path,
      skip_upload_aab: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      metadata_path: "fastlane/metadata/android"
    )
  end

  # Path to Google Play service account JSON key
  private_lane :play_store_key_path do
    File.expand_path("~/.google-play/play-store-key.json")
  end
end

# ─── iOS ────────────────────────────────────────────────────

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Increment build number to avoid collisions
    increment_build_number(
      xcodeproj: "ios/Runner.xcodeproj"
    )

    # Flutter build
    sh("cd .. && flutter build ios --release")

    # Archive and upload
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store-connect",
      output_directory: "build/ios/export",
      output_name: "CastCircle.ipa"
    )

    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload metadata, screenshots, and URLs to App Store Connect"
  lane :metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload metadata only (no screenshots)"
  lane :metadata_only do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      # Auto-detect the version from the latest editable version on ASC
      skip_app_version_update: true
    )
  end

  desc "Take screenshots on all device sizes"
  lane :screenshots do
    capture_ios_screenshots(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      output_directory: "fastlane/screenshots",
      clear_previous_screenshots: true
    )
  end

  desc "Download existing metadata from App Store Connect"
  lane :fetch_metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      app_version: "1.0",
      skip_metadata: false
    )
    UI.success("Metadata downloaded to fastlane/metadata/")
  end

  # Shared API key configuration
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8"),
      in_house: false
    )
  end
end
